OPENAI_API_KEY=sk-xxxx
OPENAI_BASE_URL=

LLM_PROVIDER=openai
OPENAI_MODEL=gpt-5.4
OPENAI_WIRE_API=responses

PORT=5000
ONEBOT_PATH=/onebot/v11/ws
SYSTEM_PROMPT=你是QQ群内的AI助手。输出规则：禁止Markdown、LaTeX；简洁直接。
PROMPT_FILE=prompt.txt

# 可选：保留备用模型配置（当前简单模式下不会自动回退）
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# 触发控制
AI_REQUIRE_PREFIX=true
AI_PREFIXES=ai
# 忽略其他 WS 服务常见指令（私聊和群聊都会生效）
# 可按需增删；默认覆盖 Sakura bot 常见命令前缀
AI_IGNORE_REGEX=^(pjsk|b30|msa|msp|mysekai|tsearch|song|taikoupdate|taikorec|taikob|taikotrend|wlsk|sekai|qooapp|cnmusicupdate|cnmusicdiffupdate|sk预测|查房|分数线|段位进度|live订阅)(\\s|$)
AI_MAX_MEDIA_BYTES=10485760
AI_MEDIA_REFERER=
HTTPS_PROXY=

# 拍一拍响应
AI_POKE_ENABLE=true
AI_POKE_COOLDOWN=10
AI_POKE_REPLY_TEXT=[自动回复]
AI_POKE_ONLY_SELF=true

# 上下文记忆
AI_CONTEXT_ENABLE=true
AI_CONTEXT_WINDOW=6
AI_CONTEXT_TTL=900

# 违禁词治理
AI_MOD_ENABLE=true
AI_BAN_DURATION=600

# 图片上下文关联策略
AI_IMAGE_CONTEXT_TTL=60
AI_IMAGE_CONTEXT_REQUIRE_HINTS=true
AI_IMAGE_HINT_REGEX=(上图|这张图|图中|这幅图|图片里|这)
AI_IMAGE_CONTEXT_REQUIRE_SAME_USER=true
AI_IMAGE_CONTEXT_MODE=ai
AI_IMAGE_CONTEXT_MAX=3
AI_IMAGE_ONLY_NO_CALL=true
